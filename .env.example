# --- NVIDIA NIM (LLM) ---
# Get your key at https://build.nvidia.com
NVIDIA_API_KEY=
NVIDIA_MODEL=meta/llama-3.3-70b-instruct
NVIDIA_FALLBACK_MODEL=meta/llama-3.1-70b-instruct

# --- Database ---
# Used by the FastAPI app (asyncpg) and Alembic migrations.
# Inside docker-compose the hostname is "postgres".
DATABASE_URL=postgresql://ops:ops@localhost:5432/ops

# --- Redis (ARQ async job queue) ---
REDIS_URL=redis://localhost:6379

# --- Auth ---
# HS256 secret for JWT minting/validation — change before going to production.
JWT_SECRET_KEY=change-me-in-production
# Comma-separated API keys accepted by the X-Api-Key header.
API_KEYS=dev-key-change-me

# --- Agent guardrails ---
MAX_STEPS=6

# --- Embeddings (RAG) ---
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# --- Observability ---
# Optional Langfuse tracing — leave blank to disable.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
# Optional OpenTelemetry OTLP endpoint — leave blank to disable.
OTEL_ENDPOINT=
OTEL_SERVICE_NAME=operations-assistant

# --- CORS (frontend origin) ---
CORS_ORIGINS=http://localhost:5173
